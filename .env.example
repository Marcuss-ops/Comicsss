# =============================================================================
# Comic Video Maker — Unified Configuration (.env)
# =============================================================================
# Both Node.js (via dotenv) and Python (inherited env) read these keys.
# Keep this file at the project root. Never commit the real .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Ollama (local LLM for comic analysis)
# ---------------------------------------------------------------------------
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5vl:7b"
OLLAMA_TIMEOUT_SECONDS="300"

# ---------------------------------------------------------------------------
# Python Bridge OCR micro-service
# ---------------------------------------------------------------------------
BRIDGE_PORT="8081"
BRIDGE_URL=""
BRIDGE_TIMEOUT_MS="90000"

# ---------------------------------------------------------------------------
# Server / Dev
# ---------------------------------------------------------------------------
PORT="3000"
NODE_ENV="development"

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_WINDOW_MS="60000"
RATE_MAX="30"
